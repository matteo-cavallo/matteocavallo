---
import Layout from "./Layout.astro"
import Footer from "../components/Footer.astro"
import Hero from "../components/Hero.astro"
import Vision from "../components/Vision.astro"
import About from "../components/About.astro"
import Signature from "../components/Signature.astro"
import SiteNav from "../components/SiteNav.astro"
import SectionNav from "../components/SectionNav.astro"
import ScrollSection from "../components/ScrollSection.astro"
import KeyboardHint from "../components/KeyboardHint.astro"

interface Props {
  title?: string
  description?: string
}

const { title, description } = Astro.props

const sections = [
  { id: "hero", label: "Mission" },
  { id: "vision", label: "Vision" },
  { id: "about", label: "About" },
]

const pathname = Astro.url.pathname
---

<Layout title={title} description={description}>
  {
    /* Pre-paint gate: runs synchronously before the chrome markup below is
    parsed, so the `html.is-home` rule (which holds header/footer/section-nav
    at opacity: 0) is in effect from the very first frame. Without this, the
    module script that adds the class is deferred and the chrome flashes
    visible on hard refresh before the entry timeline begins.

    `data-astro-rerun` is required for ClientRouter navigations: Astro's
    default swap calls swapRootAttributes() which replaces the <html> class
    list with the incoming document's (empty), and inline scripts don't
    re-execute on swap unless opted in. Without this, on /about → /
    navigation the new View Transition snapshot would be captured with
    chrome at full opacity — then setup() would add `is-home` a moment
    later, causing a visible flash-then-hide before the entry fade-in.

    `releaseHomeScope()` removes the class once chrome has finished fading
    in, and `teardown()` (astro:before-swap) removes it when leaving. */
  }
  <script is:inline data-astro-rerun>
    document.documentElement.classList.add("is-home")
  </script>

  <main>
    <div
      class="relative container mx-auto flex flex-col md:grid md:h-screen md:grid-cols-1 md:grid-rows-[auto_1fr_auto] md:overflow-hidden"
    >
      <header
        data-site-header
        transition:name="site-header"
        class="flex flex-none items-center justify-center px-4 py-8 md:justify-between md:px-8"
        data-enter-chrome
      >
        <a href="/" aria-label="Matteo Cavallo">
          <Signature class="h-6 w-auto" replayOnHover />
        </a>

        <SiteNav pathname={pathname} />
      </header>

      <div
        class="no-scrollbar flex w-full flex-col items-start px-4 md:overflow-y-auto md:px-8"
        data-scroll-container
      >
        <ScrollSection id="hero" first>
          <Hero />
        </ScrollSection>
        <ScrollSection id="vision">
          <Vision />
        </ScrollSection>
        <ScrollSection id="about">
          <About />
        </ScrollSection>
      </div>

      {/* <SectionNav sections={sections} /> */}

      <div data-enter-chrome data-site-footer transition:name="site-footer">
        <Footer />
      </div>
    </div>

    {/* <KeyboardHint count={sections.length} prefix="Navigate with" /> */}
  </main>
</Layout>

<style is:global>
  /* Chrome starts hidden, revealed by entry timeline after the curtain.
     The curtain covers these elements until it exits, so this also ensures
     they remain blank for the brief moment after the curtain clears.

     Scoped to `html.is-home` — the class is added by this component's
     module script on first execution and removed after the chrome fade
     completes. Scoping prevents this global rule from leaking to any
     future page that re-uses the [data-enter-chrome] attribute without
     running an entry timeline, and `pointer-events: none` keeps
     keyboard-focus traversal out of invisible chrome during the curtain. */
  html.is-home [data-enter-chrome],
  html.is-home .section-nav {
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    html.is-home [data-enter-chrome],
    html.is-home .section-nav {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>

<script>
  /**
   * Entry animation orchestrator.
   *
   * Animation contract — dependencies on other components:
   *
   * Hero.astro:
   *   - Renders .hero-word spans (and <em> for emphasis words).
   *   - Sets initial CSS: opacity: 0; transform: translateY(0.5em) on
   *     .hero-word so the pre-JS paint matches the timeline's starting pose.
   *   - GSAP re-sets this same initial pose explicitly via gsap.set() below so
   *     the timeline doesn't depend on parsing the computed CSS translation
   *     (which is a font-metric-sensitive value).
   *   - If Hero.astro's initial CSS changes, update the gsap.set() call here.
   *
   * Curtain.astro:
   *   - Dispatches "curtain:exit-start" when its slide-out begins.
   *   - This triggers enter() with entryDelay = ENTRY_DELAY_WITH_CURTAIN
   *     (overlap with the curtain slide so the two motions rhyme).
   *   - If the curtain is absent (repeat-visit session skip, or subsequent
   *     navigation), enter() runs immediately with the "without-curtain" delay.
   *
   * [data-enter-chrome] elements (header, footer, .section-nav):
   *   - Initially hidden via <style is:global> in this file (opacity: 0).
   *   - Faded in at the tail of the entry timeline so chrome and hero blend.
   */
  import gsap from "gsap"
  import { MOTION } from "../lib/motion"
  import { REDUCED_MOTION_MQL } from "../lib/runtime"

  // Marker class that scopes the "chrome starts hidden" global style to
  // this component. The pre-paint inline script above sets this class
  // synchronously before the chrome markup is parsed (preventing a flash
  // on hard refresh where this deferred module script would otherwise
  // run after the first paint). Re-adding here is idempotent and covers
  // edge cases where this script runs without the inline gate. Removed
  // once chrome has finished fading in by releaseHomeScope().
  document.documentElement.classList.add("is-home")

  // Non-em baseline: unhurried, fluid reveal.
  const HERO_DURATION = 1.05
  const HERO_STAGGER = 0.055

  // Em peak: per-word duration and stagger when a word is fully inside the
  // emphasized phrase. The reveal ramps smoothly toward these values around
  // the phrase and back down after — a ritardando, not a step change.
  const HERO_EM_DURATION = 1.6
  const HERO_EM_STAGGER = 0.14

  // How many words on each side of the em phrase transition between the
  // baseline and peak pacing. Larger = gentler slowdown.
  const HERO_FALLOFF = 6

  // Single gentle deceleration curve used across every word; the variable
  // durations do the emphasis work, not a change of ease mid-sentence.
  // Sourced from MOTION so the entry sequence and one-shot UI fades
  // (KeyboardHint) share the same ease identity.
  const HERO_EASE = MOTION.entryEase

  // Wait past the initial slow portion of the curtain's power3.in slide
  // so the curtain has cleared enough of the hero before its words begin
  // their rise — the two motions rhyme as the curtain accelerates away.
  //
  // The exit is 1.2s of power3.in (cubic). At delay 0.55 the curtain has
  // only moved (0.55/1.2)³ ≈ 10% of the viewport — hero words begin their
  // rise while still almost entirely hidden, and the stagger is mostly
  // complete by the time the curtain clears them, so the motion reads as
  // a pop-in rather than a reveal. At 0.75 the curtain is ~24% cleared
  // and visibly accelerating, which is where "rhyme as the curtain
  // accelerates away" actually begins.
  const ENTRY_DELAY_WITH_CURTAIN = 0.75
  const ENTRY_DELAY_WITHOUT_CURTAIN = 0.1

  let entryDelay = ENTRY_DELAY_WITHOUT_CURTAIN
  let didRun = false
  let ctx: ReturnType<typeof gsap.context> | null = null

  // Called once the entry sequence is complete, regardless of the path
  // taken (normal, reduced-motion, or early return). Releases the
  // `is-home` scope on the global "chrome hidden" style so the class
  // only persists while it's actively doing work.
  function releaseHomeScope() {
    document.documentElement.classList.remove("is-home")
  }

  function enter() {
    if (didRun) return
    didRun = true

    const heroWords = Array.from(
      document.querySelectorAll<HTMLElement>(".hero-word"),
    )
    const chrome = Array.from(
      document.querySelectorAll<HTMLElement>("[data-enter-chrome]"),
    )
    const sectionNav = document.querySelector<HTMLElement>(".section-nav")
    const chromeTargets = sectionNav ? [...chrome, sectionNav] : chrome

    const prefersReducedMotion = REDUCED_MOTION_MQL.matches

    if (prefersReducedMotion) {
      gsap.set(heroWords, { opacity: 1, clearProps: "transform" })
      gsap.set(chromeTargets, { opacity: 1, clearProps: "pointerEvents" })
      releaseHomeScope()
      return
    }

    // All GSAP work for the entry sequence runs inside a context so any
    // mid-animation teardown (e.g. astro:before-swap on a future second
    // page) cleanly kills the timeline and reverts the inline styles
    // written by gsap.set / tl.to.
    ctx = gsap.context(() => {
    // Explicitly set the starting transform so GSAP doesn't infer it from
    // computed CSS. Matches Hero.astro's initial pose:
    //   opacity: 0; transform: translateY(0.5em)
    // GSAP parses the computed `translateY` in px at timeline-start time, and
    // a font-loading race can produce the wrong px value; setting it here in
    // em makes the entry timeline robust to font metric shifts.
    gsap.set(heroWords, { y: "0.5em", opacity: 0 })

    // Locate the emphasized phrase so we can ramp the pacing around it.
    const firstEm = heroWords.findIndex((w) => w.hasAttribute("data-em"))
    let lastEm = -1
    for (let i = heroWords.length - 1; i >= 0; i--) {
      if (heroWords[i].hasAttribute("data-em")) {
        lastEm = i
        break
      }
    }
    const hasEm = firstEm >= 0 && lastEm >= 0

    // Smoothstep from baseline (0) to peak (1) based on how close a word is
    // to the em phrase: 1 inside, ramping down over HERO_FALLOFF words.
    const smoothstep = (t: number) => {
      const c = Math.max(0, Math.min(1, t))
      return c * c * (3 - 2 * c)
    }
    const emWeight = (i: number): number => {
      if (!hasEm) return 0
      if (i >= firstEm && i <= lastEm) return 1
      const dist = i < firstEm ? firstEm - i : i - lastEm
      return smoothstep(1 - dist / (HERO_FALLOFF + 1))
    }

    const lerp = (a: number, b: number, t: number) => a + (b - a) * t

    // Walk the sentence once to compute per-word start time and duration.
    // The gap *after* each word (the stagger step) depends on the weight at
    // that word, so the slowdown is distributed gradually rather than
    // snapping at a boundary.
    const starts: number[] = []
    const durations: number[] = []
    let cursor = 0
    for (let i = 0; i < heroWords.length; i++) {
      const w = emWeight(i)
      starts.push(cursor)
      durations.push(lerp(HERO_DURATION, HERO_EM_DURATION, w))
      cursor += lerp(HERO_STAGGER, HERO_EM_STAGGER, w)
    }

    const onEnterDone = () => {
      gsap.set([...heroWords, ...chromeTargets], {
        clearProps: "willChange",
      })
      // Chrome has finished fading in — release the home-scope class so
      // [data-enter-chrome] elements (nav, footer, KeyboardHint) return
      // to normal pointer-events / opacity inheritance.
      releaseHomeScope()
    }

    const tl = gsap.timeline({
      delay: entryDelay,
      defaults: { ease: HERO_EASE },
      onComplete: onEnterDone,
    })

    heroWords.forEach((word, i) => {
      tl.to(
        word,
        {
          opacity: 1,
          y: 0,
          duration: durations[i],
        },
        starts[i],
      )
    })

    // Chrome fades in while the tail of the hero stagger is still animating
    // so the two phases blend into one continuous motion.
    const lastStart = starts[starts.length - 1] ?? 0
    const lastDuration = durations[durations.length - 1] ?? HERO_DURATION
    const heroEnd = lastStart + lastDuration
    tl.to(
      chromeTargets,
      {
        opacity: 1,
        duration: 1.0,
      },
      Math.max(0, heroEnd - 0.5),
    )
    })
  }

  function teardown() {
    ctx?.revert()
    ctx = null
    didRun = false
    // If we tear down before the entry completes, still release the
    // home-scope class so a subsequent page isn't stuck at opacity: 0.
    releaseHomeScope()
  }

  function setup() {
    didRun = false
    entryDelay = ENTRY_DELAY_WITHOUT_CURTAIN
    // Re-apply the home-scope class on every setup so view-transition
    // navigations back to this page restore the initial chrome pose.
    document.documentElement.classList.add("is-home")

    // The curtain is considered "present" only when it will actually play
    // its ceremony. On ClientRouter navigations within the same session,
    // the SSR markup is rendered on every page but the ceremony module
    // script won't re-run, so `curtain:exit-start` / `curtain:done` would
    // never fire — we'd stall forever at opacity: 0. The `curtain-seen`
    // class is the public contract the Curtain component exposes for the
    // "already seen, will be skipped" state; once it's on <html>, treat
    // the curtain as absent and reveal immediately with the short delay.
    const curtainEl = document.getElementById("curtain")
    const curtainSeen =
      document.documentElement.classList.contains("curtain-seen")

    if (curtainEl && !curtainSeen) {
      // Start entry as the curtain begins to slide away so the two motions
      // rhyme (the curtain uncovers exactly where the hero words rise).
      const onExitStart = () => {
        entryDelay = ENTRY_DELAY_WITH_CURTAIN
        enter()
      }
      window.addEventListener("curtain:exit-start", onExitStart, { once: true })
      // Fallback in case the exit event is missed (e.g. repeat-visit skip).
      window.addEventListener("curtain:done", enter, { once: true })
      return
    }

    // No curtain (e.g. subsequent navigation) — reveal immediately.
    enter()
  }

  // astro:page-load fires on the initial full page load AND after every
  // ClientRouter navigation, so this is the single correct hook. The prior
  // DOMContentLoaded-based onReady() wiring only ran once per session —
  // bundled module scripts don't re-execute on View Transition swaps, so
  // back-navigation to `/` would have skipped the entry sequence entirely.
  document.addEventListener("astro:page-load", setup)
  // Kill any in-flight entry timeline on view-transition navigations so
  // tweens don't continue ticking against detached DOM.
  document.addEventListener("astro:before-swap", teardown)
</script>
