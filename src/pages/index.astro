---
import Layout from "../layouts/Layout.astro"
import Curtain from "../components/Curtain.astro"
import Hero from "../components/Hero.astro"
import Sections from "../components/Sections.astro"
import Footer from "../components/Footer.astro"
---

<Layout>
  <Curtain />
  <div class="mx-auto max-w-5xl px-8 lg:px-12">
    <div class="grid grid-cols-1 md:grid-cols-2 md:gap-24 md:py-16">
      <Hero />
      <Sections />
    </div>
  </div>
  <Footer />
</Layout>
