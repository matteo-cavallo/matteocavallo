---
import Layout from "../layouts/Layout.astro"
import Hero from "../components/Hero.astro"
import Footer from "../components/Footer.astro"
import Vision from "../components/Vision.astro"
import About from "../components/About.astro"
import Sidebar from "../components/Sidebar.astro"
import Curtain from "../components/Curtain.astro"
---

<Layout>
  <main class="min-h-screen">
    <Curtain />
    <!-- Desktop: sticky 1/3 sidebar + scrollable 2/3 content -->
    <div class="hidden lg:flex">
      <aside
        class="bg-card-2 sticky top-0 h-screen w-1/3 shrink-0 overflow-y-auto border-r border-slate-200 dark:border-slate-700"
      >
        <Sidebar />
      </aside>
      <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto w-full max-w-xl">
          <Vision />
          <About />
        </div>
      </div>
    </div>
    <!-- Mobile: sticky card stack -->
    <div class="lg:hidden">
      <div class="bg-card-3 sticky top-0 z-10 min-h-screen">
        <Hero />
      </div>
      <div class="bg-card-2 sticky top-0 z-20 min-h-screen">
        <Vision />
      </div>
      <div class="bg-card-1 sticky top-0 z-30 min-h-screen">
        <About />
        <Footer />
      </div>
    </div>
  </main>
</Layout>
