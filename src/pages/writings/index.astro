---
import { getCollection } from "astro:content"
import Footer from "../../components/Footer.astro"
import Layout from "../../layouts/Layout.astro"
import WritingItem from "../../components/WritingItem.astro"

const writings = await getCollection("writings", ({ data }) => !data.draft)
writings.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<Layout
  title="Writings — Matteo Cavallo"
  description="Notes on craft, slowness, and the way things are made."
>
  <!-- <header class="mb-12">
    <h1 class="text-text mb-2 font-serif text-xl leading-snug font-normal">
      Writings
    </h1>
    <p class="text-text-muted font-serif italic">Notes from the making.</p>
  </header> -->

  <section>
    {
      writings.map((piece) => (
        <WritingItem
          title={piece.data.title}
          href={`/writings/${piece.id}`}
          date={piece.data.date}
          description={piece.data.description}
        />
      ))
    }
  </section>
</Layout>
