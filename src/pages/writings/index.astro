---
import { getCollection } from "astro:content"
import Footer from "../../components/Footer.astro"
import Layout from "../../layouts/Layout.astro"

const writings = await getCollection("writings", ({ data }) => !data.draft)
writings.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<Layout
  title="Writings — Matteo Cavallo"
  description="Notes on craft, slowness, and the way things are made."
>
  <div class="container mx-auto max-w-3xl px-4 pt-28 pb-20 md:pt-32 md:pb-24">
    <header class="mb-12 md:mb-16">
      <h1 class="mb-2 font-serif text-4xl md:text-5xl">Writings</h1>
      <p class="font-serif text-neutral-500 italic dark:text-neutral-400">
        Notes from the making.
      </p>
    </header>

    <section>
      <div class="space-y-0">
        {
          writings.map((piece) => (
            <div class="border-b border-stone-200 py-8 last:border-0 dark:border-stone-800">
              <p class="mb-2 font-sans text-xs tracking-widest text-neutral-400 uppercase dark:text-neutral-500">
                {piece.data.date.toLocaleDateString("en-US", {
                  timeZone: "UTC",
                  month: "long",
                  day: "numeric",
                  year: "numeric",
                })}
              </p>
              <a href={`/writings/${piece.id}`} class="group block">
                <h2 class="font-serif text-xl text-neutral-900 transition-colors group-hover:text-neutral-500 dark:text-neutral-100 dark:group-hover:text-neutral-400">
                  {piece.data.title}
                </h2>
              </a>
              <p class="mt-2 font-serif text-base leading-relaxed text-neutral-500 dark:text-neutral-400">
                {piece.data.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>
  </div>
  <Footer />
</Layout>
