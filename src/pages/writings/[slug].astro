---
import { getCollection, render } from "astro:content"
import type { CollectionEntry } from "astro:content"
import { Image } from "astro:assets"
import Footer from "../../components/Footer.astro"
import Layout from "../../layouts/Layout.astro"

export async function getStaticPaths() {
  const writings = await getCollection("writings", ({ data }) => !data.draft)
  return writings.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

interface Props {
  entry: CollectionEntry<"writings">
}

const { entry } = Astro.props
const { Content } = await render(entry)

const dateFormatted = entry.data.date.toLocaleDateString("en-US", {
  timeZone: "UTC",
  month: "long",
  day: "numeric",
  year: "numeric",
})
---

<Layout
  title={`${entry.data.title} — Matteo Cavallo`}
  description={entry.data.description}
>
  <div class="mx-auto max-w-2xl">
    <header class="mb-12">
      <p
        class="text-text-faint mb-4 font-sans text-xs tracking-widest uppercase"
      >
        {dateFormatted}
      </p>
      <h1 class="font-serif text-2xl leading-snug md:text-5xl">
        {entry.data.title}
      </h1>
      <p class="text-text-muted mt-4 font-serif text-xl italic">
        {entry.data.description}
      </p>
    </header>

    {
      entry.data.image && (
        <figure class="mb-12 w-fit md:mx-[-16px]">
          <Image
            src={entry.data.image}
            alt={entry.data.imageCaption ?? ""}
            class="w-auto object-contain md:max-h-[500px] md:rounded-sm"
          />
          {entry.data.imageCaption && (
            <figcaption class="text-text-faint mt-2 text-center font-sans text-xs md:px-1">
              {entry.data.imageCaption}
            </figcaption>
          )}
        </figure>
      )
    }

    <div class="article-body">
      <Content />
    </div>

    <div class="mt-12">
      <a
        href="/writings"
        class="text-text-muted hover:text-text font-sans text-sm transition-colors"
      >
        ← All writings
      </a>
    </div>
  </div>
</Layout>

<style>
  .article-body :global(p) {
    font-family: var(--font-serif);
    font-size: 1.125rem; /* text-lg — intentionally larger for long-form readability */
    line-height: 1.75;
    color: var(--color-neutral-700);
    margin-bottom: 1.75rem;
  }

  @media (prefers-color-scheme: dark) {
    .article-body :global(p) {
      color: var(--color-neutral-300);
    }
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .article-body :global(em) {
    font-style: italic;
  }

  .article-body :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .article-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.25rem; /* text-xl — aligned with heading scale */
    font-weight: 400;
    color: var(--color-text);
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .article-body :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: inherit;
  }
</style>
