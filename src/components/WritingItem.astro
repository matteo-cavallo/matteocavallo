---
interface Props {
  title: string
  href: string
  date: Date
  description: string
}

const { title, href, date, description } = Astro.props

const dateFormatted = date.toLocaleDateString("en-US", {
  timeZone: "UTC",
  month: "long",
  day: "numeric",
  year: "numeric",
})
---

<div class="border-b border-border py-6 first:pt-0 last:border-0 last:pb-0">
  <p class="mb-2 font-sans text-xs tracking-widest text-text-faint uppercase">
    {dateFormatted}
  </p>
  <a href={href} class="group inline-block">
    <p class="font-sans text-base font-medium text-text transition-colors duration-150 group-hover:text-text-muted">
      {title}
    </p>
  </a>
  <p class="mt-3 text-sm leading-relaxed text-text-muted">
    {description}
  </p>
</div>
