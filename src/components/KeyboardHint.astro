---
interface Props {
  count: number
  prefix?: string
  suffix?: string
}

const { count, prefix = "You can navigate using", suffix } = Astro.props
const keys = Array.from({ length: count }, (_, i) => i + 1)
---

<aside
  class="keyboard-hint pointer-events-none fixed right-6 bottom-6 z-10 hidden items-center gap-2 font-sans md:flex"
  aria-hidden="true"
  data-enter-chrome
  data-keyboard-hint
>
  {
    prefix && (
      <span class="text-[11px] leading-none text-neutral-400 dark:text-neutral-500">
        {prefix}
      </span>
    )
  }
  <span class="flex items-center gap-1">
    {
      keys.map((k) => (
        <kbd class="keyboard-hint-key inline-flex h-[1.125rem] min-w-[1.125rem] items-center justify-center rounded-[3px] border border-neutral-300 px-1 text-[10px] leading-none font-medium text-neutral-500 transition-[color,border-color,transform] duration-[400ms] ease-in-out dark:border-neutral-800 dark:text-neutral-400">
          {k}
        </kbd>
      ))
    }
  </span>
  {
    suffix && (
      <span class="text-[11px] leading-none text-neutral-400 dark:text-neutral-500">
        {suffix}
      </span>
    )
  }
</aside>

<style>
  /* The pressed state is a transient feedback effect (border/text color +
     a 1px vertical shift) applied via a `data-pressed` attribute from the
     keydown handler. It's kept here as a scoped rule rather than a Tailwind
     utility because the transition needs to chain off the same transition
     stack as the base rule on <kbd>, and a `data-[pressed]` variant would
     require duplicating the light/dark pair for every property. */
  .keyboard-hint-key[data-pressed] {
    color: var(--color-neutral-900);
    border-color: var(--color-neutral-900);
    transform: translateY(1px);
  }

  @media (prefers-color-scheme: dark) {
    .keyboard-hint-key[data-pressed] {
      color: var(--color-neutral-50);
      border-color: var(--color-neutral-50);
    }
  }
</style>

<script>
  import gsap from "gsap"
  import { MOTION } from "../lib/motion"
  import {
    DESKTOP_MQL,
    REDUCED_MOTION_MQL,
    withLifecycle,
  } from "../lib/runtime"

  const IDLE_HIDE_MS = 12000
  // On repeat visits the curtain is skipped entirely, so no
  // `curtain:done` event fires. Start the idle countdown after a short
  // grace window that roughly matches the chrome fade-in — long enough
  // for the hint to actually appear, short enough that the 12s window
  // still feels like "idle" to the user.
  const REPEAT_VISIT_DELAY_MS = 1200
  const SEEN_KEY = "matteo-curtain-seen"

  let cleanup: (() => void) | null = null

  function setup() {
    teardown()

    if (!DESKTOP_MQL.matches) return

    const hint = document.querySelector<HTMLElement>("[data-keyboard-hint]")
    if (!hint) return

    const keys = Array.from(
      hint.querySelectorAll<HTMLElement>(".keyboard-hint-key"),
    )
    const reduced = REDUCED_MOTION_MQL.matches

    let hideTimer: number | null = null
    let repeatVisitTimer: number | null = null
    let hidden = false
    let ctx: ReturnType<typeof gsap.context> | null = null

    const hide = () => {
      if (hidden) return
      hidden = true
      if (reduced) {
        hint.style.opacity = "0"
        return
      }
      // Context captures the one-shot fade so a mid-animation teardown
      // (e.g. astro:before-swap) cleanly kills the tween and reverts
      // the inline opacity.
      ctx = gsap.context(() => {
        gsap.to(hint, {
          opacity: 0,
          duration: 0.6,
          ease: MOTION.entryEase,
        })
      })
    }

    const startIdleTimer = () => {
      if (hideTimer !== null) window.clearTimeout(hideTimer)
      hideTimer = window.setTimeout(hide, IDLE_HIDE_MS)
    }

    // First-visit anchor: wait until the curtain ceremony is fully
    // complete before the hint is considered "visible", so the 12s
    // idle window is measured from when the user can actually see it.
    const onCurtainDone = () => startIdleTimer()
    window.addEventListener("curtain:done", onCurtainDone, { once: true })

    // Repeat-visit anchor: the curtain is skipped and no event fires,
    // so fall back to a small fixed delay that lines up with the
    // chrome fade-in on subsequent visits.
    let hasSeen = false
    try {
      hasSeen = sessionStorage.getItem(SEEN_KEY) === "1"
    } catch {
      // storage unavailable (private mode, quota) — treat as first visit
      hasSeen = false
    }
    if (hasSeen) {
      repeatVisitTimer = window.setTimeout(
        startIdleTimer,
        REPEAT_VISIT_DELAY_MS,
      )
    }

    const onKeydown = (event: KeyboardEvent) => {
      if (event.key < "1" || event.key > "9") return
      const idx = parseInt(event.key, 10) - 1
      const key = keys[idx]
      if (!key) return

      key.setAttribute("data-pressed", "")
      window.setTimeout(() => key.removeAttribute("data-pressed"), 220)

      hide()
    }

    document.addEventListener("keydown", onKeydown)

    cleanup = () => {
      document.removeEventListener("keydown", onKeydown)
      window.removeEventListener("curtain:done", onCurtainDone)
      if (hideTimer !== null) window.clearTimeout(hideTimer)
      hideTimer = null
      if (repeatVisitTimer !== null) window.clearTimeout(repeatVisitTimer)
      repeatVisitTimer = null
      ctx?.revert()
      ctx = null
    }
  }

  function teardown() {
    cleanup?.()
    cleanup = null
  }

  DESKTOP_MQL.addEventListener("change", setup)

  withLifecycle(setup, teardown)
</script>
