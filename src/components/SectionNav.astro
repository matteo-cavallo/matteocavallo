---
interface Section {
  id: string
  label: string
}

interface Props {
  sections: Section[]
}

const { sections } = Astro.props
---

<nav
  class="section-nav pointer-events-none z-10 hidden items-center justify-items-end md:col-start-1 md:row-start-2 md:mr-8 md:grid md:self-center md:justify-self-end"
  aria-label="Section navigation"
>
  {
    sections.map((section) => (
      <div
        data-wheel-slot
        class="col-start-1 row-start-1 flex items-center justify-end"
      >
        <a
          href={`#${section.id}`}
          data-section-link={section.id}
          class="group pointer-events-auto flex items-center justify-end gap-3 will-change-transform outline-none"
          aria-label={`Jump to ${section.label}`}
        >
          <span class="nav-label">{section.label}</span>
          <span class="nav-line" />
        </a>
      </div>
    ))
  }
</nav>

<script>
  /**
   * SectionNav — 3D perspective wheel navigation (desktop only).
   *
   * Animation contract:
   * - Requires window.lenisInstance to be set by SmoothScroll.astro before
   *   setup() (desktop only; mobile has no Lenis and uses native scroll).
   * - Reads [data-scroll-container] as the IntersectionObserver root on desktop.
   * - Each [data-wheel-slot] wraps an <a data-section-link> and a .nav-line.
   * - Active state is driven by an IntersectionObserver watching the section
   *   elements whose ids come from [data-section-link].
   * - Proximity/magnetic effect on desktop: gsap.quickTo on x/scale per link,
   *   with a "flatten" transition when the cursor is close to the wheel.
   * - Keyboard: digit keys 1–9 scroll to the matching section via
   *   lenis.scrollTo (or native scrollIntoView as a fallback).
   *
   * Teardown: ctx.revert() clears all GSAP state created inside the context;
   * observer.disconnect(), detachProximity(), and keydownCleanup() remove all
   * external listeners. Inline styles applied outside the context (perspective,
   * transformOrigin, transformStyle) are cleared explicitly.
   */
  import gsap from "gsap"
  import type Lenis from "lenis"
  import { MOTION } from "../lib/motion"
  import {
    DESKTOP_MQL,
    REDUCED_MOTION_MQL,
    withLifecycle,
  } from "../lib/runtime"

  let isSetUp = false
  let ctx: ReturnType<typeof gsap.context> | null = null
  let observer: IntersectionObserver | null = null
  let activeId: string | null = null
  let currentActiveIdx = 0
  let currentFlatten = 0
  let detachProximity: (() => void) | null = null
  let slotsRef: HTMLElement[] = []
  let effectsEnabledRef = false
  let keydownCleanup: (() => void) | null = null

  function getLenis(): Lenis | undefined {
    return window.lenisInstance
  }

  function smoothstep(t: number) {
    const c = Math.max(0, Math.min(1, t))
    return c * c * (3 - 2 * c)
  }

  function applySlotRotations(duration: number, immediate = false) {
    if (!effectsEnabledRef) return
    slotsRef.forEach((slot, i) => {
      const offset = i - currentActiveIdx
      const rotX = -offset * MOTION.nav.wheelAngle * (1 - currentFlatten)
      const y = offset * MOTION.nav.flatSpacing * currentFlatten
      if (immediate) {
        gsap.set(slot, { rotationX: rotX, y })
      } else {
        gsap.to(slot, {
          rotationX: rotX,
          y,
          duration,
          ease: MOTION.ease,
          overwrite: "auto",
        })
      }
    })
  }

  function setupProximity(links: HTMLAnchorElement[]): () => void {
    const xTo = links.map((link) =>
      gsap.quickTo(link, "x", {
        duration: MOTION.nav.dockDuration,
        ease: MOTION.ease,
      }),
    )
    const scaleTo = links.map((link) =>
      gsap.quickTo(link, "scale", {
        duration: MOTION.nav.dockDuration,
        ease: MOTION.ease,
      }),
    )

    const update = (mouseX: number | null, mouseY: number | null) => {
      let minDist = Infinity
      const perItemDist: number[] = []

      links.forEach((link, i) => {
        const rect = link.getBoundingClientRect()
        const cx = rect.left + rect.width / 2
        const cy = rect.top + rect.height / 2
        const dist =
          mouseX !== null && mouseY !== null
            ? Math.hypot(mouseX - cx, mouseY - cy)
            : Infinity
        perItemDist[i] = dist
        if (dist < minDist) minDist = dist
      })

      const nextFlatten =
        mouseX !== null &&
        mouseY !== null &&
        minDist < MOTION.nav.flattenThreshold
          ? 1
          : 0

      if (nextFlatten !== currentFlatten) {
        currentFlatten = nextFlatten
        applySlotRotations(MOTION.nav.flattenDuration)
      }

      links.forEach((_, i) => {
        const s =
          mouseX !== null && mouseY !== null
            ? smoothstep(1 - perItemDist[i] / MOTION.nav.dockRadius)
            : 0
        xTo[i](-s * MOTION.nav.dockPull)
        scaleTo[i](1 + s * MOTION.nav.dockScale)
      })
    }

    const onPointerMove = (event: PointerEvent) => {
      update(event.clientX, event.clientY)
    }
    const onPointerLeave = () => update(null, null)
    const onBlur = () => update(null, null)

    window.addEventListener("pointermove", onPointerMove, { passive: true })
    document.addEventListener("pointerleave", onPointerLeave)
    window.addEventListener("blur", onBlur)

    return () => {
      window.removeEventListener("pointermove", onPointerMove)
      document.removeEventListener("pointerleave", onPointerLeave)
      window.removeEventListener("blur", onBlur)
    }
  }

  function setup() {
    if (isSetUp) return

    const prefersReducedMotion = REDUCED_MOTION_MQL.matches
    const isDesktop = DESKTOP_MQL.matches

    const nav = document.querySelector<HTMLElement>(".section-nav")

    const slots = Array.from(
      document.querySelectorAll<HTMLElement>("[data-wheel-slot]"),
    )

    const navLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-section-link]"),
    )

    if (navLinks.length === 0) return
    isSetUp = true

    slotsRef = slots
    const effectsEnabled = isDesktop && !prefersReducedMotion
    effectsEnabledRef = effectsEnabled

    const scrollWrapper =
      document.querySelector<HTMLElement>("[data-scroll-container]") ??
      undefined

    const scrollToSection = (id: string) => {
      const target = document.getElementById(id)
      if (!target) return
      const lenis = getLenis()
      if (lenis) {
        lenis.scrollTo(target, {
          offset: 0,
          duration: prefersReducedMotion ? 0 : MOTION.scrollTo,
        })
      } else {
        target.scrollIntoView({
          behavior: prefersReducedMotion ? "auto" : "smooth",
          block: "start",
        })
      }
    }

    navLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const id = link.dataset.sectionLink
        if (!id) return
        event.preventDefault()
        scrollToSection(id)
      })
    })

    const onKeydown = (event: KeyboardEvent) => {
      const target = event.target
      if (
        target instanceof HTMLInputElement ||
        target instanceof HTMLTextAreaElement ||
        (target instanceof HTMLElement && target.isContentEditable)
      ) {
        return
      }

      // Number keys 1..n jump directly to that section.
      if (event.key >= "1" && event.key <= "9") {
        const idx = parseInt(event.key, 10) - 1
        const link = navLinks[idx]
        if (!link) return
        event.preventDefault()
        const id = link.dataset.sectionLink
        if (id) scrollToSection(id)
        return
      }
    }

    document.addEventListener("keydown", onKeydown)
    keydownCleanup = () => document.removeEventListener("keydown", onKeydown)

    const sectionIds = navLinks
      .map((link) => link.dataset.sectionLink)
      .filter((id): id is string => Boolean(id))

    const sectionElements = sectionIds
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => Boolean(el))

    ctx = gsap.context(() => {
      // 3D environment — owned by the context so ctx.revert() wipes all
      // perspective / transform-origin / transform-style properties on
      // teardown (no manual clearing required).
      if (nav && effectsEnabled) {
        gsap.set(nav, {
          perspective: MOTION.nav.wheelPerspective,
          perspectiveOrigin: "100% 50%",
        })
        gsap.set(slots, {
          transformOrigin: `100% 50% -${MOTION.nav.wheelRadius}px`,
          transformStyle: "preserve-3d",
        })
      }

      if (effectsEnabled) {
        gsap.set(navLinks, { x: 0, scale: 1 })
        gsap.set(slots, { rotationX: 0, y: 0 })
      }

      function setActive(nextId: string | null, immediate = false) {
        if (!nextId || nextId === activeId) return
        const isFirst = activeId === null
        activeId = nextId

        const activeIdx = navLinks.findIndex(
          (link) => link.dataset.sectionLink === nextId,
        )
        if (activeIdx >= 0) currentActiveIdx = activeIdx

        navLinks.forEach((link) => {
          const isActive = link.dataset.sectionLink === nextId
          link.toggleAttribute("data-active", isActive)

          const line = link.querySelector<HTMLElement>(".nav-line")
          const label = link.querySelector<HTMLElement>(".nav-label")

          if (line) {
            gsap.to(line, {
              width: isActive ? MOTION.nav.lineActive : MOTION.nav.lineInactive,
              duration: prefersReducedMotion ? 0 : MOTION.medium,
              ease: MOTION.ease,
              overwrite: "auto",
            })
          }

          if (label) {
            gsap.to(label, {
              x: isActive ? MOTION.nav.labelShiftX : 0,
              letterSpacing: isActive
                ? MOTION.nav.labelTrackingActive
                : MOTION.nav.labelTrackingInactive,
              duration: prefersReducedMotion ? 0 : MOTION.short,
              ease: MOTION.ease,
              overwrite: "auto",
            })
          }
        })

        applySlotRotations(MOTION.nav.wheelDuration, immediate || isFirst)
      }

      observer = new IntersectionObserver(
        (entries) => {
          const inView = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0]
          if (inView) setActive((inView.target as HTMLElement).id)
        },
        {
          root: isDesktop && scrollWrapper ? scrollWrapper : null,
          rootMargin: "-45% 0px -45% 0px",
          threshold: 0,
        },
      )

      sectionElements.forEach((section) => observer!.observe(section))

      setActive(sectionIds[0] ?? null, true)

      if (effectsEnabled) {
        detachProximity = setupProximity(navLinks)
      }
    })
  }

  function teardown() {
    if (!isSetUp) return
    isSetUp = false

    // Perspective / transformOrigin / transformStyle are set via gsap.set
    // inside ctx, so ctx.revert() restores them. No manual style clearing
    // needed.
    detachProximity?.()
    detachProximity = null
    keydownCleanup?.()
    keydownCleanup = null
    observer?.disconnect()
    observer = null
    ctx?.revert()
    ctx = null
    activeId = null
    currentActiveIdx = 0
    currentFlatten = 0
    slotsRef = []
    effectsEnabledRef = false
  }

  function reapply() {
    teardown()
    setup()
  }

  DESKTOP_MQL.addEventListener("change", reapply)

  withLifecycle(setup, teardown)
</script>
