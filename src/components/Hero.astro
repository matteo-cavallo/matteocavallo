---
const words: { text: string; em?: boolean; dash?: boolean }[] = [
  { text: "I" },
  { text: "craft" },
  { text: "meaningful" },
  { text: "digital" },
  { text: "experiences" },
  { text: "with" },
  { text: "care,", em: true },
  { text: "clarity", em: true },
  { text: "and", em: true },
  { text: "intention", em: true },
  { text: "—" },
  { text: "helping" },
  { text: "purpose-driven" },
  { text: "people" },
  { text: "leave" },
  { text: "things" },
  { text: "better" },
  { text: "than" },
  { text: "they" },
  { text: "found" },
  { text: "them." },
]
---

<div class="flex flex-col gap-8 pb-8 md:gap-12 md:px-0">
  <p class="font-serif text-2xl leading-tight md:text-5xl" data-hero-text>
    {
      words.map((w, i) => (
        <>
          {w.em ? (
            <em class="hero-word" data-em>
              {w.text}
            </em>
          ) : (
            <span class="hero-word" data-dash={w.dash ? "" : undefined}>
              {w.text}
            </span>
          )}
          {i < words.length - 1 ? " " : ""}
        </>
      ))
    }
  </p>
</div>

<style>
  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.5em);
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-word {
      opacity: 1;
      transform: none;
    }
  }
</style>
