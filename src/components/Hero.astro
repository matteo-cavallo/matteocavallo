---
import { Image } from "astro:assets"
import image from "../../public/matteo-2.jpeg"
import { site } from "../data/site"
---

<section
  class="mx-auto flex max-w-5xl flex-col gap-6 px-6 pt-16 pb-8 md:flex-row md:items-center md:justify-between md:gap-16 lg:gap-20 lg:pb-24"
>
  <div class="flex flex-1 flex-col gap-6 md:max-w-md">
    <p class="text-text font-serif text-[18px] leading-[1.6]">
      I craft meaningful digital experiences with care, clarity and intention —
      helping purpose-driven people leave things better than they found them.
    </p>
    <div
      class="font-handwriting text-text text-[20px] leading-normal font-bold"
    >
      <span class="block">Matteo</span>
      <span class="block">{site.author.location}</span>
    </div>
  </div>
  <figure class="shrink-0 md:w-80 lg:w-96">
    <Image
      src={image}
      alt={site.author.name}
      class="ring-divider aspect-4/3 w-full rounded-sm object-cover ring-1 md:max-w-full"
    />
  </figure>
</section>
