<script>
  import Lenis from "lenis"
  import gsap from "gsap"
  import { MOTION } from "../lib/motion"
  import {
    DESKTOP_MQL,
    REDUCED_MOTION_MQL,
    withLifecycle,
  } from "../lib/runtime"

  let lenis: Lenis | null = null

  const tick = (time: number) => {
    lenis?.raf(time * 1000)
  }

  function init() {
    if (lenis) return
    if (!DESKTOP_MQL.matches) return

    const prefersReducedMotion = REDUCED_MOTION_MQL.matches

    const container =
      document.querySelector<HTMLElement>("[data-scroll-container]") ??
      undefined

    // Lenis: when the scrollable area is an inner div (not the window),
    // both wrapper and content point to that same container element.
    //   wrapper = the element that clips / receives scroll events.
    //   content = the element whose height defines the scroll range.
    // They are identical here because our layout uses a single fixed-height
    // div as both the viewport and the scroll surface.
    lenis = new Lenis({
      ...(container ? { wrapper: container, content: container } : {}),
      duration: MOTION.lenis,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: !prefersReducedMotion,
      syncTouch: false,
    })

    window.lenisInstance = lenis

    gsap.ticker.add(tick)
    gsap.ticker.lagSmoothing(0)
  }

  function destroy() {
    if (!lenis) return
    gsap.ticker.remove(tick)
    lenis.destroy()
    lenis = null
    window.lenisInstance = undefined
  }

  function apply() {
    if (DESKTOP_MQL.matches) init()
    else destroy()
  }

  DESKTOP_MQL.addEventListener("change", apply)

  withLifecycle(apply, destroy)
</script>
