---
interface Props {
  title: string
  subtitle: string
}

const { title, subtitle } = Astro.props
---

<section class="flex flex-col gap-12">
  <div class="space-y-2">
    <h2
      class="font-serif text-2xl leading-snug font-normal text-neutral-900 md:text-3xl dark:text-neutral-100"
      data-reveal
    >
      {title}
    </h2>
    <p
      class="font-serif text-xl text-neutral-500 italic dark:text-neutral-400"
      data-reveal
    >
      {subtitle}
    </p>
  </div>
  <div class="flex w-full max-w-3xl flex-col gap-4 text-xl leading-relaxed">
    <slot />
  </div>
</section>
