---
interface Props {
  title: string
  subtitle: string
  id?: string
}

const { title, subtitle, id } = Astro.props
---

<section id={id} class="flex min-h-screen flex-col gap-8 px-8 py-16 lg:min-h-0">
  <div class="space-y-2">
    <h2
      class="font-serif text-xl leading-relaxed font-bold text-stone-900 dark:text-stone-100"
    >
      {title}
    </h2>
    <p
      class="text-md font-serif leading-relaxed text-stone-500 italic dark:text-stone-400"
    >
      {subtitle}
    </p>
  </div>
  <div class="flex flex-col gap-6 text-lg leading-relaxed">
    <slot />
  </div>
</section>
