---
interface Props {
  title: string
  subtitle: string
}

const { title, subtitle } = Astro.props
---

<section class="flex flex-col gap-8">
  <div class="will-animate">
    <h2
      class="font-serif text-[18px] leading-[1.6] font-bold text-stone-900 dark:text-stone-100"
    >
      {title}
    </h2>
    <p
      class="font-serif text-[14px] leading-[1.6] text-stone-500 italic dark:text-stone-400"
    >
      {subtitle}
    </p>
  </div>
  <div class="flex flex-col gap-6 text-base leading-[1.6]">
    <slot />
  </div>
</section>
