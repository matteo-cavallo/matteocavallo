---
interface Props {
  title: string
  subtitle: string
}

const { title, subtitle } = Astro.props
---

<section
  class="mx-auto flex max-w-5xl flex-col gap-6 px-6 py-8 md:grid md:grid-cols-12 md:gap-12 lg:gap-16 lg:py-24"
>
  <div class="md:sticky md:top-16 md:col-span-4 md:self-start">
    <h2 class="text-text font-serif text-[18px] leading-[1.6] font-bold">
      {title}
    </h2>
    <p class="text-muted font-serif text-[14px] leading-[1.6] italic">
      {subtitle}
    </p>
  </div>
  <div class="flex flex-col gap-6 text-base leading-[1.6] md:col-span-8">
    <slot />
  </div>
</section>
