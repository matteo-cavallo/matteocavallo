    d="M390.289 37.8482C390.289 37.8482 345.577 137.407 376.881 147.743C410.704 158.91 457.482 46.2323 460.68 37.8482C440.293 114.962 417.22 176.001 460.68 155.504"
  ></path>
  <!-- tt crossbar -->
  <path
    pathLength="1"
    d="M353.418 71.4642C353.155 63.927 561.001 46.8524 564.59 34.4866"></path>
  <!-- e -->
  <path
    pathLength="1"
    d="M487.495 111.803C551.811 107.841 538.352 74.6359 534.422 71.4642C515.8 56.4342 475.112 103.869 490.847 135.335C502.287 158.211 538.603 139.43 541.126 131.973"
  ></path>
  <!-- o -->
  <path
    pathLength="1"
    d="M624.925 81.549C584.282 40.2578 548.67 138.297 581.35 152.143C615.21 166.488 634.844 85.7658 614.869 98.357C594.894 110.948 641.947 148.831 668.5 108.442"
  ></path>
</svg>

<style>
  svg {
    fill: none;
  }

  svg path {
    stroke: currentColor;
    stroke-width: 15;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Animated-on-load: start hidden, transitions drive the draw-in */
  svg[data-signature] {
    opacity: 0;
    transition: opacity 400ms ease;
  }

  svg[data-signature] path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hover-replay uses the same transitions; initial state stays un-dashed so
     the signature shows fully drawn until the user interacts. */
  svg[data-signature-replay] {
    cursor: pointer;
    transition: opacity 400ms ease;
  }

  svg[data-signature-replay] path {
    transition: stroke-dashoffset 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    svg[data-signature] {
      opacity: 1 !important;
      transition: none !important;
    }

    svg[data-signature] path {
      stroke-dashoffset: 0 !important;
      transition: none !important;
    }

    svg[data-signature-replay] {
      transition: none !important;
    }

    svg[data-signature-replay] path {
      transition: none !important;
    }
  }
</style>

<script>
  import { MOTION } from "../lib/motion"
  import { REDUCED_MOTION_MQL, onReady } from "../lib/runtime"

  const STAGGER = 250
  const HOVER_DEBOUNCE = 80

  // End-to-end handwriting time in milliseconds. MOTION.signatureDraw owns
  // the value in seconds (shared with Curtain.astro's timeline reservation);
  // we convert once for setTimeout parity.
  //
  // Opacity fades IN PARALLEL with the first stroke — it is NOT additive to
  // the total. Total = (pathCount - 1) * STAGGER + single-draw duration.
  const TOTAL_DRAW_MS = MOTION.signatureDraw * 1000

  function play(svg: SVGSVGElement) {
    const paths = svg.querySelectorAll<SVGPathElement>("path")
    svg.style.opacity = "1"
    paths.forEach((path, i) => {
      setTimeout(() => {
        path.style.strokeDashoffset = "0"
      }, i * STAGGER)
    })
  }

  function reset(svg: SVGSVGElement) {
    const paths = svg.querySelectorAll<SVGPathElement>("path")

    paths.forEach((path) => {
      path.style.transition = "none"
      path.style.strokeDasharray = "1"
      path.style.strokeDashoffset = "1"
    })
    svg.style.transition = "none"
    svg.style.opacity = "0"

    // Force reflow so the transitions apply cleanly on the next frame.
    void svg.getBoundingClientRect()

    paths.forEach((path) => {
      path.style.transition = ""
    })
    svg.style.transition = ""
  }


  function initAnimated() {
    if (REDUCED_MOTION_MQL.matches) return

    document
      .querySelectorAll<SVGSVGElement>("svg[data-signature]")
      .forEach((svg) => {
        const delay = Number(svg.dataset.delay ?? 0)
        setTimeout(() => play(svg), delay)
      })
  }

  function initHoverReplay() {
    const reduced = REDUCED_MOTION_MQL.matches

    document
      .querySelectorAll<SVGSVGElement>("svg[data-signature-replay]")
      .forEach((svg) => {
        let hoverTimer: number | null = null
        let playing = false

        const replay = () => {
          if (reduced || playing) return
          playing = true
          reset(svg)
          requestAnimationFrame(() => {
            play(svg)
            window.setTimeout(() => {
              playing = false
            }, TOTAL_DRAW_MS)
          })
        }

        const onEnter = () => {
          if (hoverTimer) window.clearTimeout(hoverTimer)
          hoverTimer = window.setTimeout(replay, HOVER_DEBOUNCE)
        }

        const onLeave = () => {
          if (hoverTimer) {
            window.clearTimeout(hoverTimer)
            hoverTimer = null
          }
        }

        svg.addEventListener("pointerenter", onEnter)
        svg.addEventListener("pointerleave", onLeave)
        svg.addEventListener("focus", onEnter)
        svg.addEventListener("blur", onLeave)
      })
  }

  function boot() {
    initAnimated()
    initHoverReplay()
  }

  onReady(boot)
</script>
