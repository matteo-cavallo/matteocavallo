---
import { site } from "../data/site"
---

<footer class="border-divider bg-bg mt-auto border-t">
  <div class="container mx-auto px-6 py-12 sm:px-8 sm:py-16">
    <div
      class="mx-auto flex max-w-5xl flex-col justify-between gap-8 md:flex-row"
    >
      <div class="will-animate space-y-2">
        <p class="text-muted font-sans text-sm">Made slowly in Paris.</p>
        <p class="text-muted/60 font-sans text-sm">
          © {site.author.name} 2025 All Rights Reserved
        </p>
      </div>

      <div class="will-animate flex flex-wrap items-start gap-6 delay-100">
        <a
          href={`mailto:${site.author.email}`}
          class="text-muted hover:text-text font-sans text-sm font-medium transition-colors duration-150"
        >
          Email
        </a>
        <a
          href={site.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted hover:text-text font-sans text-sm font-medium transition-colors duration-150"
        >
          Instagram
        </a>
        <a
          href={site.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted hover:text-text font-sans text-sm font-medium transition-colors duration-150"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
