---
import { Icon } from "astro-icon/components"
import { site } from "../data/site"

const socials = [
  {
    href: `mailto:${site.author.email}`,
    icon: "lucide:mail",
    label: "Email",
  },
  {
    href: site.social.instagram,
    icon: "simple-icons:instagram",
    label: "Instagram",
    external: true,
  },
  {
    href: site.social.linkedin,
    icon: "simple-icons:linkedin",
    label: "LinkedIn",
    external: true,
  },
]
---

<footer
  class="container mx-auto border-t border-neutral-200 px-4 py-8 tracking-wide md:border-t-0 md:py-8 dark:border-neutral-800"
>
  <div
    class="flex flex-col items-center justify-start gap-4 text-center md:items-start md:gap-4 md:text-left"
  >
    <div
      class="flex flex-row items-baseline gap-2 md:flex-col md:gap-0 md:space-y-2"
    >
      <p
        class="font-sans text-xs text-neutral-400 md:text-sm dark:text-neutral-500"
      >
        {site.tagline}
      </p>
      <p
        class="font-sans text-xs text-neutral-400 md:text-sm dark:text-neutral-500"
      >
        © {site.author.name}
        {new Date().getFullYear()}<span class="hidden md:inline">
          All Rights Reserved</span
        >
      </p>
    </div>
    <div class="flex items-center gap-4">
      {
        socials.map(({ href, icon, label, external }) => (
          <a
            href={href}
            aria-label={label}
            target={external ? "_blank" : undefined}
            rel={external ? "noopener noreferrer" : undefined}
            class="inline-flex text-neutral-400 transition-colors duration-200 hover:text-neutral-900 dark:text-neutral-500 dark:hover:text-neutral-100"
          >
            <Icon name={icon} class="h-4 w-4 md:h-3 md:w-3" />
          </a>
        ))
      }
    </div>
  </div>
</footer>
