---
import { Icon } from "astro-icon/components"
import { site } from "../data/site"

const socials = [
  {
    href: `mailto:${site.author.email}`,
    icon: "lucide:mail",
    label: "Email",
  },
  {
    href: site.social.instagram,
    icon: "simple-icons:instagram",
    label: "Instagram",
    external: true,
  },
  {
    href: site.social.linkedin,
    icon: "simple-icons:linkedin",
    label: "LinkedIn",
    external: true,
  },
]
---

<footer class="px-4 py-8 tracking-wide md:px-0">
  <div class="flex flex-col justify-start gap-4">
    <div class="space-y-2">
      <p class="font-sans text-sm text-neutral-400 dark:text-neutral-500">
        {site.tagline}
      </p>
      <p class="font-sans text-sm text-neutral-400 dark:text-neutral-500">
        © {site.author.name}
        {new Date().getFullYear()} All Rights Reserved
      </p>
    </div>
    <div class="flex items-center gap-4">
      {
        socials.map(({ href, icon, label, external }) => (
          <a
            href={href}
            aria-label={label}
            target={external ? "_blank" : undefined}
            rel={external ? "noopener noreferrer" : undefined}
            class="inline-flex text-neutral-400 transition-colors duration-200 hover:text-neutral-900 dark:text-neutral-500 dark:hover:text-neutral-100"
          >
            <Icon name={icon} class="h-3 w-3" />
          </a>
        ))
      }
    </div>
  </div>
</footer>
