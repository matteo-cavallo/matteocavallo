---
import { site } from "../data/site"
---

<footer class="mt-auto border-t border-gray-200 bg-white">
  <div class="container mx-auto px-6 py-12 sm:px-8 sm:py-16">
    <div
      class="mx-auto flex max-w-5xl flex-col justify-between gap-8 md:flex-row"
    >
      <div class="space-y-2">
        <p class="font-sans text-sm text-gray-600">Made slowly in Paris.</p>
        <p class="font-sans text-sm text-gray-400">
          © {site.author.name} 2025 All Rights Reserved
        </p>
      </div>

      <div class="flex flex-wrap items-start gap-6">
        <a
          href={`mailto:${site.author.email}`}
          class="font-sans text-sm font-medium text-gray-600 transition-colors duration-200 hover:text-gray-900"
        >
          Email
        </a>
        <a
          href={site.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="font-sans text-sm font-medium text-gray-600 transition-colors duration-200 hover:text-gray-900"
        >
          Instagram
        </a>
        <a
          href={site.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="font-sans text-sm font-medium text-gray-600 transition-colors duration-200 hover:text-gray-900"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
