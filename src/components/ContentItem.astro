---
interface Props {
  title: string
  subtitle: string
  period: string
  description: string
  href?: string
}

const { title, subtitle, period, description, href } = Astro.props
---

<div class="border-divider border-b pb-6 last:border-0">
  <div
    class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4"
  >
    <div class="flex-1">
      {
        href ? (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-block"
          >
            <p class="text-text group-hover:text-muted font-sans text-base font-medium transition-colors duration-150">
              {title}
            </p>
          </a>
        ) : (
          <p class="text-text font-sans text-base font-medium">{title}</p>
        )
      }
      <p
        class:list={["text-muted font-sans text-sm", href ? "mt-1" : "mt-0.5"]}
      >
        {subtitle}
      </p>
    </div>
    <p class="text-muted shrink-0 font-sans text-sm tabular-nums">
      {period}
    </p>
  </div>
  <p class="text-muted mt-3 text-sm leading-relaxed">
    {description}
  </p>
</div>
