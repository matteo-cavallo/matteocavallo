---
interface Props {
  title: string
  subtitle: string
  period: string
  description: string
  href?: string
}

const { title, subtitle, period, description, href } = Astro.props
---

<div class="border-b border-stone-200 pb-6 last:border-0 dark:border-stone-700">
  <div
    class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4"
  >
    <div class="flex-1">
      {
        href ? (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-block"
          >
            <p class="font-sans text-base font-medium text-stone-900 transition-colors duration-150 group-hover:text-stone-500 dark:text-stone-100 dark:group-hover:text-stone-400">
              {title}
            </p>
          </a>
        ) : (
          <p class="font-sans text-base font-medium text-stone-900 dark:text-stone-100">
            {title}
          </p>
        )
      }
      <p
        class:list={[
          "font-sans text-sm text-stone-500 dark:text-stone-400",
          href ? "mt-1" : "mt-0.5",
        ]}
      >
        {subtitle}
      </p>
    </div>
    <p
      class="shrink-0 font-sans text-sm text-stone-500 tabular-nums dark:text-stone-400"
    >
      {period}
    </p>
  </div>
  <p class="mt-3 text-sm leading-relaxed text-stone-500 dark:text-stone-400">
    {description}
  </p>
</div>
