---
interface Props {
  title: string
  subtitle: string
  period: string
  description: string
  href?: string
}

const { title, subtitle, period, description, href } = Astro.props
---

<div class="border-b border-gray-100 pb-6 last:border-0">
  <div
    class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4"
  >
    <div class="flex-1">
      {
        href ? (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-block"
          >
            <p class="font-sans text-base font-medium text-gray-900 transition-colors duration-200 group-hover:text-gray-600">
              {title}
            </p>
          </a>
        ) : (
          <p class="font-sans text-base font-medium text-gray-900">{title}</p>
        )
      }
      <p
        class:list={[
          "font-sans text-sm text-gray-500",
          href ? "mt-1" : "mt-0.5",
        ]}
      >
        {subtitle}
      </p>
    </div>
    <p class="shrink-0 font-sans text-sm text-gray-400 tabular-nums">
      {period}
    </p>
  </div>
  <p class="mt-3 text-sm leading-relaxed text-gray-600">
    {description}
  </p>
</div>
