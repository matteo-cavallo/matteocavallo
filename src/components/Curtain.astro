---
import Signature from "./Signature.astro"
---

<div
  id="curtain"
  class="fixed inset-0 z-50 flex flex-col items-center justify-center gap-5 bg-stone-100 px-2 dark:bg-stone-900"
>
  <p
    id="curtain-quote"
    class="max-w-lg text-center text-2xl text-stone-900 dark:text-stone-100"
  >
    I believe that good work can change things — for people, for communities,
    for the world around us.
  </p>

  <Signature
    class="h-7 text-stone-900 dark:text-stone-100"
    animated
    delay={1000}
  />
</div>

<style>
  #curtain-quote {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 700ms cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 700ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  #curtain-quote.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #curtain {
    transition: transform 900ms cubic-bezier(0.76, 0, 0.24, 1);
    will-change: transform;
  }

  #curtain.is-exiting {
    transform: translateY(-100%);
  }

  @media (prefers-reduced-motion: reduce) {
    #curtain-quote {
      opacity: 1;
      transform: none;
      transition: none;
    }

    #curtain-quote.is-visible {
      opacity: 1;
      transform: none;
    }

    #curtain {
      transition: opacity 400ms ease;
      transform: none !important;
    }

    #curtain.is-exiting {
      opacity: 0;
    }
  }
</style>

<script>
  const QUOTE_IN = 200
  const EXIT_AT = 750 + 5 * 250 + 500 + 1000
  const EXIT_DURATION = 900

  const curtain = document.getElementById("curtain")!
  const quote = document.getElementById("curtain-quote")!

  document.body.style.overflow = "hidden"

  setTimeout(() => quote.classList.add("is-visible"), QUOTE_IN)

  setTimeout(() => {
    curtain.classList.add("is-exiting")
    setTimeout(() => {
      document.body.style.overflow = ""
      curtain.remove()
    }, EXIT_DURATION + 50)
  }, EXIT_AT)
</script>
