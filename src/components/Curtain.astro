---
import Signature from "./Signature.astro"

const quote = [
  { text: "I" },
  { text: "believe" },
  { text: "that" },
  { text: "good", em: true },
  { text: "work", em: true },
  { text: "can" },
  { text: "change" },
  { text: "things" },
  { text: "—", dash: true },
  { text: "for" },
  { text: "people," },
  { text: "for" },
  { text: "communities," },
  { text: "for" },
  { text: "the" },
  { text: "world" },
  { text: "around" },
  { text: "us." },
]

// Settle beat between the curtain appearing and the word reveal starting,
// so the text doesn't animate the instant the curtain paints.
const ENTRY_DELAY_MS = 500

// Signature's own handwriting animation runs on DOMContentLoaded with the
// given delay. We offset it so it starts as the word reveal finishes, and
// shift it by the entry delay so it stays aligned with the word animation.
const SIGNATURE_DELAY_MS = 2200 + ENTRY_DELAY_MS
---

{
  /* Pre-paint gate: runs synchronously before the curtain markup is parsed,
    so on repeat visits within the same tab the curtain is hidden by CSS
    from the very first frame (no flash on fast refresh).
    The key is duplicated in the module script below — keep them in sync. */
}
<script is:inline>
  try {
    if (sessionStorage.getItem("matteo-curtain-seen") === "1") {
      document.documentElement.classList.add("curtain-seen")
    }
  } catch (e) {
    // ignore storage failures (private mode, quota, etc.)
  }
</script>

<div
  id="curtain"
  aria-hidden="true"
  role="presentation"
  class="fixed inset-0 z-100 flex flex-col items-center justify-center gap-12 bg-neutral-100 px-6 dark:bg-neutral-950"
>
  <p
    id="curtain-quote"
    class="max-w-xl text-center font-serif text-2xl leading-snug text-neutral-900 md:text-3xl dark:text-neutral-50"
  >
    {
      quote.map((word, i) => (
        <>
          {word.em ? (
            <em class="word" data-word-index={i} data-em>
              {word.text}
            </em>
          ) : (
            <span
              class="word"
              data-word-index={i}
              data-dash={word.dash ? "" : undefined}
            >
              {word.text}
            </span>
          )}
          {i < quote.length - 1 ? " " : ""}
        </>
      ))
    }
  </p>

  <Signature
    class="h-6 text-neutral-900 md:h-7 dark:text-neutral-50"
    animated
    delay={SIGNATURE_DELAY_MS}
  />
</div>

<style>
  /* Repeat-visit: skip the curtain entirely so a fast refresh doesn't
     show it for a single frame before the module script can remove it.
     The `curtain-seen` class is set by the pre-paint inline script above,
     before this element is parsed, so the browser never builds a box. */
  :global(html.curtain-seen) #curtain {
    display: none !important;
  }

  #curtain {
    touch-action: none;
    will-change: transform;
    /* Pin to the small viewport height so the mobile URL bar
       collapsing/expanding mid-animation can't resize the curtain and
       cause it to jump. Falls back to 100vh on older browsers. */
    height: 100vh;
    height: 100svh;
  }

  /* The quote fades in from transparent at the start of the timeline.
     We intentionally do NOT set `opacity: 0` here: if the module script
     fails to load (e.g. transient CDN 404) the text must still be
     readable. The module script applies the initial opacity just before
     animating it in, so the fade still works when JS is available. */
  #curtain-quote {
    will-change: opacity;
  }

  #curtain-quote .word {
    display: inline-block;
    opacity: 0.2;
    /* Match the JS entry state so the words paint in their pre-animation
       pose on first frame. Without this, GSAP's initial `y: 8` is applied
       one frame after the browser has already painted the words at y: 0,
       which shows up as a visible jolt on slower devices. */
    transform: translateY(8px);
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    #curtain-quote .word {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import gsap from "gsap"
  import { MOTION } from "../lib/motion"
  import { REDUCED_MOTION_MQL, onReady } from "../lib/runtime"

  const SEEN_KEY = "matteo-curtain-seen"

  // Word reveal
  const WORD_START = 0.2
  const WORD_DURATION = 1.1
  const WORD_STAGGER = 0.05
  const EM_EMPHASIS = 0.08
  const DASH_BREATH = 0.22

  // Gentle fade-in for the quote container at the very start of the
  // timeline. Compounds with the per-word opacity so the text appears
  // softly before the words begin their staggered rise.
  const QUOTE_FADE_DURATION = 0.9

  // Must match the `delay` prop passed to <Signature /> above (seconds).
  // Signature draw duration is owned by MOTION.signatureDraw (shared with
  // Signature.astro) so the two cannot drift apart.
  const SIGNATURE_START = 2.2

  const HOLD = 0.65
  const EXIT_DURATION = 1.2
  // Exit accelerates away (slow start → fast exit) so the curtain reads as
  // leaving, not as easing in and out of rest.
  const EXIT_EASE = "power3.in"

  // Matches ENTRY_DELAY_MS in the component frontmatter — a small beat so
  // the word reveal doesn't start the instant the curtain paints.
  const ENTRY_DELAY = 0.5

  // Locks scroll during curtain display.
  // Both html/body overflow and Lenis are stopped to prevent any scroll
  // input from reaching the page before the curtain exits — html/body
  // overflow catches native scroll (desktop without Lenis, and mobile),
  // and lenis.stop() halts the Lenis RAF loop on desktop.
  function lockScroll() {
    document.documentElement.style.overflow = "hidden"
    document.body.style.overflow = "hidden"
    window.lenisInstance?.stop()
  }

  function unlockScroll() {
    document.documentElement.style.overflow = ""
    document.body.style.overflow = ""
    window.lenisInstance?.start()
  }

  function dispatchDone() {
    window.dispatchEvent(new CustomEvent("curtain:done"))
  }

  // Signals Home.astro to begin the hero word-stagger entry timeline.
  // Home.astro listens once for this event and calls enter() with the
  // "with-curtain" delay so the two motions rhyme.
  function dispatchExitStart() {
    window.dispatchEvent(new CustomEvent("curtain:exit-start"))
  }

  function markSeen() {
    try {
      sessionStorage.setItem(SEEN_KEY, "1")
    } catch {
      // ignore storage failures (private mode, quota, etc.)
    }
  }

  function hasBeenSeen(): boolean {
    try {
      return sessionStorage.getItem(SEEN_KEY) === "1"
    } catch {
      return false
    }
  }

  function run() {
    const curtain = document.getElementById("curtain")
    const quote = document.getElementById("curtain-quote")
    if (!curtain || !quote) return

    // Repeat-visit gate: within the same tab session, skip the ceremony.
    // Defer the event so listeners registered in the same tick (e.g. Home's
    // entry script) can subscribe before it fires. Skip `exit-start` so the
    // home entry uses its short delay (no curtain = nothing to rhyme with).
    if (hasBeenSeen()) {
      curtain.remove()
      requestAnimationFrame(() => dispatchDone())
      return
    }

    const words = Array.from(quote.querySelectorAll<HTMLElement>(".word"))
    const prefersReducedMotion = REDUCED_MOTION_MQL.matches

    lockScroll()

    if (prefersReducedMotion) {
      gsap.to(curtain, {
        autoAlpha: 0,
        duration: 0.5,
        delay: 0.7 + ENTRY_DELAY,
        ease: "power2.out",
        onStart: dispatchExitStart,
        onComplete: () => {
          unlockScroll()
          curtain.remove()
          markSeen()
          dispatchDone()
        },
      })
      return
    }

    // Compute per-word delays so em words get a micro-emphasis lift and the
    // em-dash gets a short "breath" before the sentence resumes.
    const dashIdx = words.findIndex((w) => w.hasAttribute("data-dash"))
    const wordDelay = (i: number): number => {
      let d = i * WORD_STAGGER
      if (words[i].hasAttribute("data-em")) d += EM_EMPHASIS
      if (dashIdx >= 0 && i >= dashIdx) d += DASH_BREATH
      return d
    }

    const tl = gsap.timeline({
      delay: ENTRY_DELAY,
      defaults: { ease: "power2.out" },
      onComplete: () => {
        unlockScroll()
        curtain.remove()
        markSeen()
        dispatchDone()
      },
    })

    // Start the quote fully transparent only once we know GSAP is loaded
    // and we're about to animate it back in. If the module script ever
    // fails to load, the CSS default keeps the text visible.
    gsap.set(quote, { opacity: 0 })

    tl.to(
      quote,
      {
        opacity: 1,
        duration: QUOTE_FADE_DURATION,
        ease: MOTION.entryEase,
      },
      0,
    )

    tl.to(
      words,
      {
        opacity: 1,
        y: 0,
        duration: WORD_DURATION,
        stagger: wordDelay,
      },
      WORD_START,
    )

    // Anchor the end of the signature's self-playing handwriting slice so
    // the slide is scheduled only after it completes, with a trailing hold
    // for breathing. Using a label (rather than tl.set({},{},pos)) keeps the
    // timing relationship explicit and named.
    tl.addLabel("sig-end", SIGNATURE_START + MOTION.signatureDraw)

    tl.to(
      curtain,
      {
        yPercent: -100,
        duration: EXIT_DURATION,
        ease: EXIT_EASE,
        onStart: () => {
          curtain.style.pointerEvents = "none"
          dispatchExitStart()
        },
      },
      `sig-end+=${HOLD}`,
    )
  }

  // Wait until the web fonts are resolved before starting the ceremony.
  // The quote is set in Libre Baskerville; if we animate while the fallback
  // serif is still showing, the swap to Baskerville reflows the centered
  // block and reads as a sudden jump (especially on mobile). The curtain is
  // already covering the page during this wait so the delay is invisible.
  function start() {
    const FONT_TIMEOUT_MS = 1200
    const ready =
      document.fonts && typeof document.fonts.ready?.then === "function"
        ? document.fonts.ready
        : Promise.resolve()
    const timeout = new Promise((resolve) =>
      window.setTimeout(resolve, FONT_TIMEOUT_MS),
    )
    Promise.race([ready, timeout]).then(() => run())
  }

  onReady(start)
</script>
