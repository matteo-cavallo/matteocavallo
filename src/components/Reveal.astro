---
// Scroll-triggered reveal for elements marked with [data-reveal] inside a
// [data-reveal-section]. First-time visibility animates children in with a
// small stagger; direction-aware y offset matches the user's scroll momentum.
---

<style is:global>
  [data-reveal-section] [data-reveal] {
    opacity: 0;
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal-section] [data-reveal] {
      opacity: 1;
    }
  }
</style>

<script>
  import gsap from "gsap"
  import type Lenis from "lenis"
  import {
    DESKTOP_MQL,
    REDUCED_MOTION_MQL,
    withLifecycle,
  } from "../lib/runtime"

  const REVEAL_DURATION = 0.95
  const REVEAL_STAGGER = 0.09
  const REVEAL_OFFSET = 14

  let ctx: ReturnType<typeof gsap.context> | null = null
  let observer: IntersectionObserver | null = null
  let scrollCleanup: (() => void) | null = null
  let scrollDir: 1 | -1 = 1

  function getScrollRoot(): HTMLElement | null {
    return document.querySelector<HTMLElement>("[data-scroll-container]")
  }

  // Lenis 1.x exposes `direction` (+1 down, -1 up, 0 idle) on its scroll
  // event payload (the event carries the Lenis instance itself). Reading
  // it straight from the event avoids maintaining a previous-scroll
  // variable and diffing against it every frame.
  function handleLenisScroll(e: Lenis) {
    if (e.direction === 1 || e.direction === -1) scrollDir = e.direction
  }

  // Fallback path (mobile / no Lenis): native scroll events don't carry
  // a direction, so we fall back to diffing the container's scrollTop.
  let lastScrollY = 0
  function handleNativeScroll(target: HTMLElement | Window) {
    const y = target instanceof Window ? target.scrollY : target.scrollTop
    if (y === lastScrollY) return
    scrollDir = y >= lastScrollY ? 1 : -1
    lastScrollY = y
  }

  function trackScrollDirection() {
    const lenis = window.lenisInstance
    if (lenis) {
      lenis.on("scroll", handleLenisScroll)
      scrollCleanup = () => lenis.off("scroll", handleLenisScroll)
      return
    }

    const root = getScrollRoot()
    const isDesktop = DESKTOP_MQL.matches
    const target: HTMLElement | Window =
      root && isDesktop ? root : window
    lastScrollY = target instanceof Window ? target.scrollY : target.scrollTop
    const listener = () => handleNativeScroll(target)
    target.addEventListener("scroll", listener, { passive: true })
    scrollCleanup = () => target.removeEventListener("scroll", listener)
  }

  function revealSection(section: HTMLElement) {
    const targets = Array.from(
      section.querySelectorAll<HTMLElement>("[data-reveal]"),
    )
    if (!targets.length) return

    const fromY = scrollDir >= 0 ? REVEAL_OFFSET : -REVEAL_OFFSET

    // Wrap the tween creation in ctx.add() so GSAP associates it with
    // the live context even though this call originates from an async
    // IntersectionObserver callback (outside the context's synchronous
    // init). ctx.add(fn) invokes fn immediately and captures any GSAP
    // animations created inside it, so ctx.revert() on teardown will
    // kill in-flight reveal tweens.
    const run = () => {
      gsap.fromTo(
        targets,
        { opacity: 0, y: fromY },
        {
          opacity: 1,
          y: 0,
          duration: REVEAL_DURATION,
          ease: "power2.out",
          stagger: REVEAL_STAGGER,
          onComplete: () => {
            // Clear both the transform left by the tween AND the
            // will-change hint so the browser can release compositor
            // layers after a one-shot reveal.
            gsap.set(targets, { clearProps: "transform,willChange" })
          },
        },
      )
    }
    if (ctx) ctx.add(run)
    else run()
  }

  function setup() {
    teardown()

    const reduced = REDUCED_MOTION_MQL.matches
    const sections = document.querySelectorAll<HTMLElement>(
      "[data-reveal-section]",
    )
    if (!sections.length) return

    if (reduced) {
      sections.forEach((section) => {
        const targets = section.querySelectorAll<HTMLElement>("[data-reveal]")
        gsap.set(targets, { opacity: 1, clearProps: "willChange" })
      })
      return
    }

    trackScrollDirection()

    const isDesktop = DESKTOP_MQL.matches
    const scrollRoot = getScrollRoot()

    // All GSAP work runs inside this context so ctx.revert() on teardown
    // kills any in-flight reveal tweens and removes their inline styles —
    // important for view-transition navigations that swap the DOM while
    // a reveal is mid-animation.
    ctx = gsap.context(() => {
      observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return
            const section = entry.target as HTMLElement
            revealSection(section)
            observer?.unobserve(section)
          })
        },
        {
          root: isDesktop && scrollRoot ? scrollRoot : null,
          rootMargin: "0px 0px -15% 0px",
          threshold: 0,
        },
      )

      sections.forEach((section) => observer!.observe(section))
    })
  }

  function teardown() {
    observer?.disconnect()
    observer = null
    scrollCleanup?.()
    scrollCleanup = null
    ctx?.revert()
    ctx = null
  }

  withLifecycle(setup, teardown)
</script>
