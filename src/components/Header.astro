---
import Signature from "./Signature.astro"
---

<header class="border-text/10 bg-bg/60 backdrop-blur-md">
  <div
    class="container mx-auto flex max-w-3xl items-center justify-between px-4 py-6"
  >
    <a href="/" aria-label="Home">
      <Signature class="text-text h-4 w-auto" />
    </a>

    <nav class="flex items-center gap-6">
      <a
        href="/writings"
        class="text-text-muted hover:text-text font-sans text-sm tracking-wide transition-colors"
      >
        Writings
      </a>
    </nav>
  </div>
</header>