---
import Signature from "./Signature.astro"
---

<header
  class="fixed top-0 right-0 left-0 z-10 border-neutral-900/10 bg-neutral-50/60 backdrop-blur-md dark:border-neutral-50/10 dark:bg-neutral-950/60"
>
  <div
    class="container mx-auto flex max-w-3xl items-center justify-between px-4 py-6"
  >
    <a href="/" aria-label="Home">
      <Signature class="h-6 w-auto text-neutral-900 dark:text-neutral-50" />
    </a>

    <nav class="flex items-center gap-6">
      <a
        href="/writings"
        class="font-sans text-sm tracking-wide text-neutral-600 transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-50"
      >
        Writings
      </a>
    </nav>
  </div>
</header>
