---
import { getCollection } from "astro:content"
import Section from "./Section.astro"
import WritingItem from "./WritingItem.astro"

const writings = await getCollection("writings", ({ data }) => !data.draft)
writings.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
const featured = writings.slice(0, 2)
---

<Section title="Writings" subtitle="Notes from the making.">
  <div class="w-full" data-reveal>
    {
      featured.map((piece) => (
        <WritingItem
          title={piece.data.title}
          href={`/writings/${piece.id}`}
          date={piece.data.date}
          description={piece.data.description}
        />
      ))
    }
  </div>
  <a
    href="/writings"
    class="font-sans text-sm text-text-muted no-underline hover:underline"
  >
    All writings →
  </a>
</Section>
